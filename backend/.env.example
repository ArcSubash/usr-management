PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_secret_key

ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123

# To enable real Nodemailer Email sending, generate an "App Password" on your Gmail account
# Go to Manage google account in your account -> Search App passwords -> Create password
# copy and paste the google account's gmail address and the 16 digit password below.

SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_16_digit_app_password(no space)


# and the change this file's name to `.env`